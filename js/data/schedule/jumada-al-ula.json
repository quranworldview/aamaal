  "theme": {
    "en": "Ikhlas — For Allah or for People?",
    "hi": "इख़लास — अल्लाह के लिए या लोगों के लिए?",
    "ur": "اخلاص — اللہ کے لیے یا لوگوں کے لیے؟"
  },
  "theme_arabic": "إخْلَاص",
  "theme_ayah": {
    "surah": 98,
    "ayah": 5,
    "arabic": "وَمَا أُمِرُوا إِلَّا لِيَعْبُدُوا اللَّهَ مُخْلِصِينَ لَهُ الدِّينَ",
    "translation": {
      "en": "And they were not commanded except to worship Allah, sincere to Him in religion.",
      "hi": "और उन्हें सिर्फ़ यही हुक्म दिया गया कि अल्लाह की इबादत करें उसी के लिए दीन में ख़ालिस होकर।",
      "ur": "اور انہیں صرف یہی حکم دیا گیا کہ اللہ کی عبادت کریں اسی کے لیے دین میں خالص ہو کر۔"
    }
  },
  "month_question": {
    "en": "If no one could see what I do this month — would I still do it the same way?",
    "hi": "अगर इस महीने जो करूँ कोई देख न सके — तो क्या वैसे ही करूँगा?",
    "ur": "اگر اس مہینے جو کروں کوئی دیکھ نہ سکے — تو کیا ویسے ہی کروں گا؟"
  },
