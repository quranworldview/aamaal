  "hijri_year": 1447,
  "theme": {
    "en": "Ramadan ke baad bhi rukna nahi",
    "hi": "रमज़ान के बाद भी रुकना नहीं",
    "ur": "رمضان کے بعد بھی رکنا نہیں"
  },
  "theme_arabic": "اسْتِقَامَة",
  "theme_ayah": {
    "surah": 16,
    "ayah": 92,
    "arabic": "وَلَا تَكُونُوا كَالَّتِي نَقَضَتْ غَزْلَهَا مِن بَعْدِ قُوَّةٍ أَنكَاثًا",
    "translation": {
      "en": "And do not be like she who unravelled her spun thread after it was strong.",
      "hi": "और उस औरत जैसे मत बनो जिसने मज़बूत धागा बुनने के बाद उसे उधेड़ दिया।",
      "ur": "اور اس عورت جیسے مت بنو جس نے مضبوط دھاگا بُننے کے بعد اسے اُدھیڑ دیا۔"
    }
  },
  "month_question": {
    "en": "What from Ramadan am I actually keeping — and what have I already let go?",
    "hi": "रमज़ान से क्या मैंने सच में पकड़ा हुआ है — और क्या छोड़ दिया?",
    "ur": "رمضان سے کیا میں نے سچ میں پکڑا ہوا ہے — اور کیا چھوڑ دیا؟"
  },
