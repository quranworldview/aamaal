  "theme_arabic": "أُضْحِيَة",
  "theme_ayah": {
    "surah": 22,
    "ayah": 37,
    "arabic": "لَن يَنَالَ اللَّهَ لُحُومُهَا وَلَا دِمَاؤُهَا وَلَٰكِن يَنَالُهُ التَّقْوَىٰ مِنكُمْ",
    "translation": {
      "en": "Never will their flesh reach Allah, nor their blood — but what reaches Him is piety from you.",
      "hi": "न उनका गोश्त अल्लाह तक पहुँचता है न उनका ख़ून — लेकिन उस तक तुम्हारी तक़वा पहुँचती है।",
      "ur": "نہ ان کا گوشت اللہ تک پہنچتا ہے نہ ان کا خون — لیکن اس تک تمہاری تقوی پہنچتی ہے۔"
    }
  },
  "month_question": {
    "en": "What comfort am I holding onto that is getting between me and growth?",
    "hi": "कौन-सा आराम है जिसे मैं पकड़े हूँ और जो मुझे आगे बढ़ने से रोक रहा है?",
    "ur": "کون سا آرام ہے جسے میں پکڑے ہوں اور جو مجھے آگے بڑھنے سے روک رہا ہے؟"
  },
