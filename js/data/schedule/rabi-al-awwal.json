  "theme": {
    "en": "Love of the Prophet ﷺ — Follow, Don't Just Celebrate",
    "hi": "नबी ﷺ की मोहब्बत — सिर्फ़ मनाओ नहीं, पैरवी करो",
    "ur": "محبت نبی ﷺ — صرف مناؤ نہیں، پیروی کرو"
  },
  "theme_arabic": "مَحَبَّة",
  "theme_ayah": {
    "surah": 3,
    "ayah": 31,
    "arabic": "قُلْ إِن كُنتُمْ تُحِبُّونَ اللَّهَ فَاتَّبِعُونِي",
    "translation": {
      "en": "Say: if you love Allah, then follow me.",
      "hi": "कहो: अगर तुम अल्लाह से मोहब्बत करते हो, तो मेरी पैरवी करो।",
      "ur": "کہو: اگر تم اللہ سے محبت کرتے ہو، تو میری پیروی کرو۔"
    }
  },
  "month_question": {
    "en": "Which Sunnah of the Prophet ﷺ am I living — and which am I only knowing?",
    "hi": "नबी ﷺ की कौन-सी सुन्नत जी रहा हूँ — और कौन-सी सिर्फ़ जानता हूँ?",
    "ur": "نبی ﷺ کی کون سی سنت جی رہا ہوں — اور کون سی صرف جانتا ہوں؟"
  },
